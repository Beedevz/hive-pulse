# App
APP_ENV=development
API_PORT=8080

# JWT (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Database (both values must use the same password)
POSTGRES_PASSWORD=your-strong-password-here
DATABASE_URL=postgres://hivepulse:your-strong-password-here@localhost:5432/hivepulse?sslmode=disable

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
